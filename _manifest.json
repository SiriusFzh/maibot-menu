{
  "manifest_version": 2,
  "id": "maibot.menu",
  "version": "1.0.0",
  "plugin_type": "tool",
  "name": "菜单插件",
  "description": "发送 /菜单 即可生成一张菜单图片，列出当前麦麦所有可用功能和指令。",
  "author": {
    "name": "SiriusFzh",
    "url": "https://github.com/SiriusFzh"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/SiriusFzh/maibot-menu",
    "homepage": "https://github.com/SiriusFzh/maibot-menu"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
